rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow write: if request.auth != null;
      allow read: if true;
    }

    match /user/{uid}/songs/{docId} {
      allow write, delete: if request.auth.uid == request.resource.data.uid;
      allow read: if true;
    }

    match /user/{uid}/links/{docId} {
      allow write, delete: if request.auth.uid == request.resource.data.uid;
      allow read: if true;
    }

    match /user/{userId}/requests/{requestId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;

        allow create: if request.resource.data.keys().hasOnly(['id', 'title', 'artist', 'status', 'createdAt'])
            && exists(/databases/$(database)/documents/user/$(userId)/songs/$(request.resource.data.songId))
            && request.resource.data.status == 'open'
            && request.resource.data.createdAt is timestamp;
    }
    
    match /feedback/{docId} {
      allow write: if true;
      allow read: if true;
    }

    // Custom default security rules for FireCMS. Modifying this rule will the usage of the FireCMS.
    match /{document=**} {
        allow read, write: if request.auth.token.fireCMSUser;
    }
  }
}